<?xml version="1.0"?>
<model>
  <name>ingenuity</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>temporal-hack</name>
  </author>
  <description>
    Hand-authored Ingenuity stand-in (NASA's Mars helicopter): a small
    box fuselage, two coaxial rotor disks (scaled cylinders), and four
    angled landing legs. Geometric stand-in for the real .usdc asset
    in srb_assets — does not fly, just visible. A follow-up will
    replace this with a mesh extracted from the upstream USDC.
  </description>
</model>
