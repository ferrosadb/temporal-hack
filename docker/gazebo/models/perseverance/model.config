<?xml version="1.0"?>
<model>
  <name>perseverance</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>temporal-hack</name>
  </author>
  <description>
    Hand-authored Perseverance stand-in (NASA Mars 2020 rover): a
    flat deck body, six wheels in rocker-bogie configuration, an RTG
    box at the rear, a forward mast with a camera head, and a folded
    robotic arm. Geometric stand-in for srb_assets' perseverance.usdc
    — does not drive, just visible. A follow-up will replace this
    with a mesh extracted from the upstream USDC.
  </description>
</model>
